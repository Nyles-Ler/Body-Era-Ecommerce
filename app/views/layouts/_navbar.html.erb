<!-- Navigation bar displayed on every page with links to the main storefront pages -->

<nav class="navbar navbar-expand-lg navbar-dark bodyera-navbar">
  <div class="container">

    <!-- Brand link -->
    <%= link_to "BodyEra",
        root_path,
        class: "navbar-brand bodyera-text fw-bold" %>

    <!-- Navigation links and search -->
    <div class="collapse navbar-collapse" id="bodyeraNavigation">

      <div class="navbar-nav me-auto">
        <%= link_to "Products",
            products_path,
            class: "nav-link bodyera-nav-link" %>

        <%= link_to "Categories",
            categories_path,
            class: "nav-link bodyera-nav-link" %>

        <%= link_to "About",
            about_path,
            class: "nav-link bodyera-nav-link" %>
      </div>

      <!-- Sends the search query to the product index page -->
      <%= form_with url: products_path,
          method: :get,
          local: true,
          class: "d-flex mt-3 mt-lg-0" do %>

        <%= text_field_tag :search,
            params[:search],
            class: "form-control me-2",
            placeholder: "Search products...",
            aria: { label: "Search products" } %>

        <%= submit_tag "Search",
            class: "btn bodyera-button" %>
      <% end %>

    </div>
  </div>
</nav>