<!-- Product Index -->
<!-- Displays all active products and supports simple keyword searching -->

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Shop Products</h1>

    <p class="text-muted mb-0">
      Browse the BodyEra fitness apparel collection.
    </p>
  </div>

  <span class="badge bodyera-badge fs-6">
    <%= pluralize(@products.count, "product") %>
  </span>
</div>

<% if params[:search].present? %>
  <div class="alert bodyera-alert mb-4">
    Showing results for:
    <strong><%= params[:search] %></strong>

    <%= link_to "Clear search",
        products_path,
        class: "ms-2 bodyera-link" %>
  </div>
<% end %>

<% if @products.any? %>
  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card bodyera-product-card h-100">

          <% product_image = product.product_images.first %>

          <% if product_image.present? %>
            <%= image_tag product_image.image_url,
                alt: product_image.alt_text,
                class: "card-img-top bodyera-product-image" %>
          <% else %>
            <div class="bodyera-image-placeholder">
              No image available
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">
            <p class="bodyera-category-label mb-2">
              <%= product.category.name %>
            </p>

            <h2 class="h5 card-title">
              <%= product.name %>
            </h2>

            <p class="card-text text-muted product-description">
              <%= truncate(product.description, length: 90) %>
            </p>

            <p class="bodyera-price fs-5 fw-bold mt-auto">
              <%= number_to_currency(product.current_price) %>
            </p>

            <%= link_to "View Product",
                product_path(product),
                class: "btn bodyera-button w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <h2 class="h4">No products found</h2>

    <p class="text-muted">
      Try another search term or view the complete product collection.
    </p>

    <%= link_to "View All Products",
        products_path,
        class: "btn bodyera-button" %>
  </div>
<% end %>