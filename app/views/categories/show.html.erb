<!-- Category Show Page -->
<!-- Displays all active products belonging to one category -->

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="bodyera-category-label mb-2">
      Product Category
    </p>

    <h1 class="mb-1">
      <%= @category.name %>
    </h1>

    <p class="text-muted mb-0">
      <%= @category.description %>
    </p>
  </div>

  <span class="badge bodyera-badge fs-6">
    <%= pluralize(@products.count, "product") %>
  </span>
</div>

<% if @products.any? %>
  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card bodyera-product-card h-100">

          <% product_image = product.product_images.first %>

          <% if product_image.present? %>
            <%= image_tag product_image.image_url,
                alt: product_image.alt_text,
                class: "card-img-top bodyera-product-image" %>
          <% else %>
            <div class="bodyera-image-placeholder">
              No image available
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">
            <h2 class="h5 card-title">
              <%= product.name %>
            </h2>

            <p class="card-text text-muted product-description">
              <%= truncate(product.description, length: 90) %>
            </p>

            <p class="bodyera-price fs-5 fw-bold mt-auto">
              <%= number_to_currency(product.current_price) %>
            </p>

            <%= link_to "View Product",
                product_path(product),
                class: "btn bodyera-button w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <h2 class="h4">No products available</h2>

    <p class="text-muted">
      This category does not currently contain any active products.
    </p>

    <%= link_to "View All Categories",
        categories_path,
        class: "btn bodyera-button" %>
  </div>
<% end %>

<div class="mt-4">
  <%= link_to "Back to Categories",
      categories_path,
      class: "btn btn-outline-secondary" %>
</div>